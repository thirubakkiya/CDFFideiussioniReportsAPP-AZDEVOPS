# Development Environment Configuration
# NODE_ENV is automatically set to 'development' by react-scripts
# REACT_APP_ENV can be used to explicitly set environment

NODE_ENV=development
REACT_APP_ENV=development

# Optional: Override API URL (defaults to http://localhost:8088/api)
REACT_APP_API_URL=http://localhost:8088/api

# Debug logging
REACT_APP_DEBUG=true
