# Production Environment Configuration
# NODE_ENV is automatically set to 'production' by react-scripts during build

NODE_ENV=production
REACT_APP_ENV=production

# Optional: Override Production API URL (defaults to /api - relative path)
# REACT_APP_API_URL_PRODUCTION=https://api.sella.it/cdf-reports/api

# Debug logging disabled for production
REACT_APP_DEBUG=false
